<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <!-- Emulator Screen -->
    <com.moonlight.moongba.EmulatorView
        android:id="@+id/emulatorView"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Top Bar: ROM name + buttons -->
    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:layout_gravity="top"
        android:background="#CC000000"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="8dp"
        android:paddingEnd="4dp">

        <TextView
            android:id="@+id/tvRomName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="No ROM loaded"
            android:textColor="#FFFFFF"
            android:textSize="11sp"
            android:maxLines="1"
            android:ellipsize="end" />

        <Button
            android:id="@+id/btnLoadRom"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:text="Load ROM"
            android:textSize="10sp"
            android:paddingStart="8dp"
            android:paddingEnd="8dp" />

        <Button
            android:id="@+id/btnStartStop"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:text="Start"
            android:textSize="10sp"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:layout_marginStart="4dp" />

        <Button
            android:id="@+id/btnMenu"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:text="⋮"
            android:textSize="14sp"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:layout_marginStart="2dp" />

    </LinearLayout>

    <!-- Virtual Keypad — bottom overlay -->
    <LinearLayout
        android:id="@+id/virtualKeypad"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="#BB000000"
        android:orientation="horizontal"
        android:padding="6dp"
        android:gravity="center_vertical">

        <!-- LEFT: D-Pad -->
        <GridLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:columnCount="3"
            android:rowCount="3"
            android:gravity="center">

            <!-- Row 1 -->
            <Space
                android:layout_width="48dp"
                android:layout_height="48dp" />
            <Button
                android:id="@+id/btnUp"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:text="▲"
                android:textSize="16sp"
                android:padding="0dp"
                android:backgroundTint="#554466FF" />
            <Space
                android:layout_width="48dp"
                android:layout_height="48dp" />

            <!-- Row 2 -->
            <Button
                android:id="@+id/btnLeft"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:text="◀"
                android:textSize="16sp"
                android:padding="0dp"
                android:backgroundTint="#554466FF" />
            <Space
                android:layout_width="48dp"
                android:layout_height="48dp" />
            <Button
                android:id="@+id/btnRight"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:text="▶"
                android:textSize="16sp"
                android:padding="0dp"
                android:backgroundTint="#554466FF" />

            <!-- Row 3 -->
            <Space
                android:layout_width="48dp"
                android:layout_height="48dp" />
            <Button
                android:id="@+id/btnDown"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:text="▼"
                android:textSize="16sp"
                android:padding="0dp"
                android:backgroundTint="#554466FF" />
            <Space
                android:layout_width="48dp"
                android:layout_height="48dp" />

        </GridLayout>

        <!-- CENTER: L, R, Select, Start -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <!-- L and R shoulder buttons -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/btnL"
                    android:layout_width="52dp"
                    android:layout_height="36dp"
                    android:text="L"
                    android:textSize="13sp"
                    android:padding="0dp"
                    android:backgroundTint="#55666666" />

                <Space
                    android:layout_width="24dp"
                    android:layout_height="1dp" />

                <Button
                    android:id="@+id/btnR"
                    android:layout_width="52dp"
                    android:layout_height="36dp"
                    android:text="R"
                    android:textSize="13sp"
                    android:padding="0dp"
                    android:backgroundTint="#55666666" />

            </LinearLayout>

            <!-- Select and Start -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="6dp">

                <Button
                    android:id="@+id/btnSelect"
                    android:layout_width="56dp"
                    android:layout_height="32dp"
                    android:text="SELECT"
                    android:textSize="8sp"
                    android:padding="0dp"
                    android:backgroundTint="#55888888" />

                <Space
                    android:layout_width="8dp"
                    android:layout_height="1dp" />

                <Button
                    android:id="@+id/btnStart"
                    android:layout_width="56dp"
                    android:layout_height="32dp"
                    android:text="START"
                    android:textSize="8sp"
                    android:padding="0dp"
                    android:backgroundTint="#55888888" />

            </LinearLayout>

        </LinearLayout>

        <!-- RIGHT: A and B buttons -->
        <GridLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:columnCount="2"
            android:rowCount="2"
            android:gravity="center">

            <!-- Row 1 -->
            <Space
                android:layout_width="52dp"
                android:layout_height="52dp" />
            <Button
                android:id="@+id/btnA"
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:text="A"
                android:textSize="18sp"
                android:textStyle="bold"
                android:padding="0dp"
                android:backgroundTint="#55CC2222" />

            <!-- Row 2 -->
            <Button
                android:id="@+id/btnB"
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:text="B"
                android:textSize="18sp"
                android:textStyle="bold"
                android:padding="0dp"
                android:backgroundTint="#552255CC" />
            <Space
                android:layout_width="52dp"
                android:layout_height="52dp" />

        </GridLayout>

    </LinearLayout>

</FrameLayout>
